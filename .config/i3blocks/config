separator_block_width=15
separator=true
markup=caskaydia

[CPU]
command=~/.config/i3blocks/cpu.sh
interval=5
color=#ffffff

[GPU]
command=~/.config/i3blocks/gpu
interval=5
color=#ffffff

[RAM]
command=~/.config/i3blocks/ram
interval=5
color=#ffffff

[Tailscale]
command=~/.config/i3blocks/tailscale.sh
interval=5
color=#ffffff

# adjust the net-script parameter according to your PC, like "eth0" or similar for WiFi
[Net]
command=~/.config/i3blocks/net enp2s0
interval=5
color=#ffffff

[Uptime]
command=~/.config/i3blocks/uptime
interval=60
color=#ffffff

[date]
command=~/.config/i3blocks/date
interval=1
color=#ffffff
